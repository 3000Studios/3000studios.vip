# Local/deploy variable names only. Do not commit real values.

# Cloudflare deploy/API
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=replace-with-cloudflare-account-id
CF_PAGES_PROJECT=3000studios-vip
CITADEL_LIVE_URL=https://3000studios.vip

# Worker/API runtime
APP_ENV=production
ACCESS_REQUIRED=1
OWNER_EMAIL=owner@example.com
ALERT_FROM_EMAIL=alerts@example.com
MAILCHANNELS_API_KEY=replace-with-mailchannels-key
DUDE_SYNC_TOKEN=replace-with-random-token

# Web build
VITE_API_BASE=https://api.example.com
VITE_VAULT_USERNAME=owner@example.com
VITE_VAULT_PASSCODE_SHA256=sha256-passcode-hex
VITE_VAULT_SECRET_ANSWER_SHA256=sha256-secret-answer-hex
VITE_STREAM_CUSTOMER_CODE=optional-cloudflare-stream-customer-code
VITE_STREAM_LIVE_INPUT_ID=optional-cloudflare-stream-live-input-id
VITE_STREAM_TITLE=3000 Studios Private Stream
