{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "packages/shared/AGENTS.md",
    "apps/web/AGENTS.md",
    "apps/api/AGENTS.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "*.lock",
      "package-lock.json",
      ".turbo/**",
      ".next/**",
      ".cache/**",
      "apps/web/dist/**",
      "apps/api/.wrangler/**"
    ]
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8000
  },
  "agent": {
    "build": {
      "permission": {
        "bash": {
          "*": "ask",
          "npm run dev*": "allow",
          "npm run build*": "allow",
          "npm run lint*": "allow",
          "npm run test*": "allow",
          "npm run format*": "allow",
          "npx wrangler *": "allow",
          "npx turbo *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git branch*": "allow",
          "git checkout*": "allow",
          "git stash*": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "rg *": "allow",
          "fd *": "allow",
          "bat *": "allow",
          "eza *": "allow",
          "pwd": "allow",
          "where *": "allow",
          "node *": "allow",
          "python *": "allow",
          "pip list*": "allow",
          "powershell *": "allow"
        }
      }
    }
  }
}
