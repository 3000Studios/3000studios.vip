  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "allowScripts": {
