{
  "name": "3000studios-vip",
  "version": "1.0.0",
  "packageManager": "npm@11.12.1",
  "description": "",
  "private": true,
  "engines": { "node": ">=22" },
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check:placeholders": "node scripts/check-no-placeholders.mjs",
