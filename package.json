    "format": "turbo format",
    "env:sync": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Sync-CloudflareEnv.ps1",
    "deploy:cloudflare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Deploy-Cloudflare.ps1",
    "hooks:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/Install-GitDeployHooks.ps1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/3000Studios/3000studios.vip.git"
  },
  "keywords": [],
  "author": "",
